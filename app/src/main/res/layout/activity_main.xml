<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nowe zwierzę" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Podaj imię" />

    <EditText
        android:id="@+id/imie"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="podaj imię zwierzęcia"
        android:inputType="text" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Wybierz gromadę" />

    <Spinner
        android:id="@+id/gromada"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/gromada" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Wpisz gatunek" />

    <EditText
        android:id="@+id/gatunek"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="podaj gatunek"
        android:inputType="text" />

    <CheckBox
        android:id="@+id/wymarle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Czy wymarłe" />

    <TextView
        android:id="@+id/textView5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tryb życia" />

    <RadioGroup
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/radioButtonDzienny"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="dzienny" />

        <RadioButton
            android:id="@+id/radioButtonNocny"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="nocny" />
    </RadioGroup>

    <Switch
        android:id="@+id/switch1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Czy domowy" />

    <TextView
        android:id="@+id/textView6"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Maksymalny wiek" />

    <SeekBar
        android:id="@+id/wiek"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/textView7"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rodzaj odżywiania" />

    <CheckBox
        android:id="@+id/mieso"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mięsożerny" />

    <CheckBox
        android:id="@+id/rosliny"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Roślinożerny" />

    <TextView
        android:id="@+id/textView8"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Waga" />

    <EditText
        android:id="@+id/waga"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="number"
        android:hint="podaj wagę"/>

    <Button
        android:id="@+id/buttonDodaj"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dodaj" />

    <TextView
        android:id="@+id/textViewKomunikat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TextView" />

</LinearLayout>